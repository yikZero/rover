---
interface Props {
  rank: number
  finalScore: string
}

const { rank, finalScore } = Astro.props
const isTop = rank <= 3
---

<div
  class:list={[
    'inline-flex items-center rounded-full px-2.5 py-0.5 font-semibold text-xs',
    isTop
      ? 'bg-primary text-primary-foreground'
      : 'bg-muted text-muted-foreground',
  ]}
>
  {finalScore}
</div>
