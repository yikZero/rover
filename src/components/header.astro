---
import { getRelativeLocaleUrl } from 'astro:i18n'
import type { Locale } from '@/i18n/utils'
import { defaultLocale, stripLocalePrefix, useTranslations } from '@/i18n/utils'
import Icon from '@/components/icon.astro'

const locale = (Astro.currentLocale ?? defaultLocale) as Locale
const t = useTranslations(locale)

const homeHref = getRelativeLocaleUrl(locale, '/')
const digestsHref = getRelativeLocaleUrl(locale, '/digests')
const aboutHref = getRelativeLocaleUrl(locale, '/about')

const targetLocale: Locale = locale === 'zh-CN' ? 'en' : 'zh-CN'
const cleanPath = stripLocalePrefix(Astro.url.pathname)
const targetPath = getRelativeLocaleUrl(targetLocale, cleanPath)

const pathname = Astro.url.pathname

const navLinks = [
  { label: t('nav.digests'), href: digestsHref },
  { label: t('nav.about'), href: aboutHref },
]

function isActive(href: string) {
  return pathname === href || pathname.startsWith(`${href}/`)
}
---

<header class="pointer-events-none sticky top-0 z-50 h-20 safe-area-top">
  <div class="absolute inset-0 bg-gradient-to-b from-background via-background/60 to-transparent"></div>
  <div class="pointer-events-auto relative mx-auto flex h-14 max-w-5xl items-center px-6">
    <a href={homeHref} class="flex items-center text-foreground transition-opacity hover:opacity-60" aria-label="Rover">
      <svg class="size-6 shrink-0" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="32" height="32" rx="8" fill="currentColor" />
      </svg>
    </a>

    <nav class="ml-auto hidden items-center gap-1 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'rounded-md px-3 py-1.5 font-medium text-sm transition-colors hover:text-foreground',
            isActive(link.href) ? 'text-foreground' : 'text-muted-foreground',
          ]}
        >
          {link.label}
        </a>
      ))}
      <button
        type="button"
        id="header-search-trigger"
        class="flex size-8 cursor-pointer items-center justify-center rounded-md text-muted-foreground transition-colors hover:text-foreground"
        aria-label={t('home.search')}
      >
        <Icon name="search" class="size-4" />
      </button>
      <a
        href={targetPath}
        class="locale-switch flex items-center gap-1 rounded-md px-2 py-1.5 font-medium text-muted-foreground text-sm transition-colors hover:text-foreground"
        aria-label={t('footer.switchTo')}
        data-locale={targetLocale}
      >
        <Icon name="globe" class="size-3.5" />
        <span>{locale === 'zh-CN' ? 'EN' : '中文'}</span>
      </a>
    </nav>

    <button
      type="button"
      id="menu-toggle"
      class="ml-auto flex size-8 cursor-pointer items-center justify-center rounded-md text-muted-foreground transition-colors hover:text-foreground md:hidden"
      aria-label="Menu"
    >
      <Icon name="menu" class="size-5" />
    </button>
  </div>
</header>

<nav
  id="mobile-drawer"
  class="pointer-events-none fixed inset-0 z-50 flex flex-col bg-background opacity-0 transition-opacity duration-200 md:hidden safe-area-top"
>
  <div class="flex h-14 items-center justify-between px-6">
    <a href={homeHref} class="flex items-center text-foreground" aria-label="Rover">
      <svg class="size-6 shrink-0" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="32" height="32" rx="8" fill="currentColor" />
      </svg>
    </a>
    <button
      type="button"
      id="menu-close"
      class="flex size-8 cursor-pointer items-center justify-center text-muted-foreground transition-colors hover:text-foreground"
      aria-label="Close"
    >
      <Icon name="x" class="size-5" />
    </button>
  </div>

  <div class="flex flex-1 flex-col overflow-y-auto px-6">
    {navLinks.map((link) => (
      <div>
        <div
          aria-hidden
          class="h-px bg-[length:4px_1px] bg-repeat-x opacity-20 [background-image:linear-gradient(90deg,var(--color-foreground)_1px,transparent_1px)]"
        ></div>
        <a
          href={link.href}
          class:list={[
            'block py-5 font-medium leading-snug transition-colors',
            isActive(link.href) ? 'text-foreground' : 'text-muted-foreground',
          ]}
        >
          {link.label}
        </a>
      </div>
    ))}
    <div
      aria-hidden
      class="h-px bg-[length:4px_1px] bg-repeat-x opacity-20 [background-image:linear-gradient(90deg,var(--color-foreground)_1px,transparent_1px)]"
    ></div>
  </div>

  <div class="flex items-center justify-between px-6 pb-10 pt-6 safe-area-bottom">
    <button
      type="button"
      id="mobile-search-trigger"
      class="flex flex-1 items-center justify-center gap-1.5 border-border border-r text-sm text-muted-foreground transition-colors"
    >
      <Icon name="search" class="size-3.5" />
      <span>{t('home.search')}</span>
    </button>
    <a
      href={targetPath}
      class="locale-switch flex flex-1 items-center justify-center gap-1.5 text-sm text-muted-foreground transition-colors"
      aria-label={t('footer.switchTo')}
      data-locale={targetLocale}
    >
      <Icon name="globe" class="size-3.5" />
      <span>{locale === 'zh-CN' ? 'EN' : '中文'}</span>
    </a>
  </div>
</nav>

<script>
  document.addEventListener('astro:page-load', () => {
    const dialog = document.getElementById('search-dialog') as HTMLDialogElement | null
    const input = document.getElementById('search-input') as HTMLInputElement | null
    const trigger = document.getElementById('header-search-trigger')
    const drawer = document.getElementById('mobile-drawer')
    const menuToggle = document.getElementById('menu-toggle')
    const menuClose = document.getElementById('menu-close')
    const mobileSearchTrigger = document.getElementById('mobile-search-trigger')

    function openSearch() {
      if (!dialog || !input) return
      dialog.showModal()
      input.focus()
    }

    function openDrawer() {
      if (!drawer) return
      drawer.classList.remove('opacity-0', 'pointer-events-none')
      drawer.classList.add('opacity-100', 'pointer-events-auto')
      document.body.style.overflow = 'hidden'
    }

    function closeDrawer() {
      if (!drawer) return
      drawer.classList.remove('opacity-100', 'pointer-events-auto')
      drawer.classList.add('opacity-0', 'pointer-events-none')
      document.body.style.overflow = ''
    }

    function onTriggerClick() {
      openSearch()
    }

    function onMobileSearchClick() {
      closeDrawer()
      openSearch()
    }

    trigger?.addEventListener('click', onTriggerClick)
    menuToggle?.addEventListener('click', openDrawer)
    menuClose?.addEventListener('click', closeDrawer)
    mobileSearchTrigger?.addEventListener('click', onMobileSearchClick)

    document.querySelectorAll<HTMLAnchorElement>('.locale-switch').forEach((el) => {
      el.addEventListener('click', () => {
        const locale = el.dataset.locale
        if (locale) localStorage.setItem('preferred-locale', locale)
      })
    })

    document.addEventListener('astro:before-swap', () => {
      trigger?.removeEventListener('click', onTriggerClick)
      menuToggle?.removeEventListener('click', openDrawer)
      menuClose?.removeEventListener('click', closeDrawer)
      mobileSearchTrigger?.removeEventListener('click', onMobileSearchClick)
    }, { once: true })
  })
</script>
