---
import type { Locale } from '@/i18n/utils'
import { richText, useTranslations } from '@/i18n/utils'
import type { DigestWithArticles } from '@/lib/types'
import { getDigestList } from '@/lib/queries'
import DigestList from '@/components/digest-list.astro'
import StatusState from '@/components/status-state.astro'
import BaseLayout from '@/layouts/base.astro'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const t = useTranslations(locale)

let initialData: { digests: DigestWithArticles[]; nextCursor: string | null } = { digests: [], nextCursor: null }
let error = false
try {
  initialData = await getDigestList()
} catch {
  error = true
}
---

<BaseLayout locale={locale} title={t('digests.title')} description={t('site.description')}>
  <section>
    <h2
      class="text-balance font-semibold text-2xl text-muted-foreground"
      set:html={richText(t('digests.digestHistory'))}
    />
    {error ? (
      <StatusState
        icon="circle-alert"
        title={t('error.title')}
        description={t('error.description')}
        href={Astro.url.pathname}
        ctaIcon="rotate-cw"
        ctaLabel={t('error.retry')}
        class="mt-16"
      />
    ) : (
      <DigestList
        locale={locale}
        initialDigests={initialData.digests}
        nextCursor={initialData.nextCursor}
      />
    )}
  </section>
</BaseLayout>
