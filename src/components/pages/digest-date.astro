---
import type { Locale } from '@/i18n/utils'
import { richText, useTranslations } from '@/i18n/utils'
import type { DigestWithArticles } from '@/lib/types'
import DigestCard from '@/components/digest-card.astro'
import BaseLayout from '@/layouts/base.astro'

interface Props {
  locale: Locale
  date: string
  digest: DigestWithArticles
}

const { locale, date, digest } = Astro.props
const t = useTranslations(locale)

const articleTitles = digest.articles
  .slice(0, 3)
  .map((a) => locale === 'zh-CN' ? a.titleZh : a.titleEn)
  .filter(Boolean)
  .join(' · ')
const pageDescription = articleTitles || t('site.description')
---

<BaseLayout locale={locale} title={`${date} ${t('digestDate.pageTitle')} - Rover`} description={pageDescription} ogType="article">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: `${date} ${t('digestDate.pageTitle')}`,
    datePublished: date,
    publisher: { '@type': 'Organization', name: 'Rover' },
  })} />
  <section>
    <div>
      <h1 class="text-balance font-semibold text-2xl text-muted-foreground">
        {date}{' '}
        <Fragment set:html={richText(t('digestDate.digest'))} />
      </h1>
      {digest.stats.fetched > 0 && (
        <p class="mt-1.5 font-normal text-muted-foreground text-sm">
          {t('digestDate.fetched', { count: digest.stats.fetched })} ·{' '}
          {t('digestDate.selected', { count: digest.stats.selected })}
        </p>
      )}
    </div>
    <div class="mt-8 md:mt-16">
      {digest.articles.map((article) => (
        <DigestCard article={article} locale={locale} />
      ))}
    </div>
  </section>
</BaseLayout>
