---
import { getRelativeLocaleUrl } from 'astro:i18n'
import type { Locale } from '@/i18n/utils'
import { useTranslations } from '@/i18n/utils'

const locale = (Astro.currentLocale ?? 'zh-CN') as Locale
const t = useTranslations(locale)
const targetLocale: Locale = locale === 'zh-CN' ? 'en' : 'zh-CN'
const cleanPath = Astro.url.pathname.replace(/^\/en(\/|$)/, '/')
const targetPath = getRelativeLocaleUrl(targetLocale, cleanPath)
---

<a
  href={targetPath}
  class="text-muted-foreground text-sm transition-colors hover:text-foreground"
>
  {t('footer.switchTo')}
</a>
