---
import { getRelativeLocaleUrl } from 'astro:i18n'
import type { Locale } from '@/i18n/utils'
import { useTranslations } from '@/i18n/utils'

const locale = (Astro.currentLocale ?? 'zh-CN') as Locale
const t = useTranslations(locale)
const targetLocale = locale === 'zh-CN' ? 'en' : 'zh-CN'

const pathSegments = Astro.url.pathname.replace(/^\/(?:zh-CN|en)\/?/, '/').replace(/\/$/, '') || '/'
const targetPath = getRelativeLocaleUrl(targetLocale, pathSegments)
---

<a
  href={targetPath}
  class="text-muted-foreground text-sm transition-colors hover:text-foreground"
>
  {t('footer.switchTo')}
</a>
