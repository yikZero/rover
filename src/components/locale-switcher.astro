---
import type { Locale } from '@/i18n/utils'
import { useTranslations } from '@/i18n/utils'

const locale = (Astro.currentLocale ?? 'zh-CN') as Locale
const t = useTranslations(locale)
const targetLocale: Locale = locale === 'zh-CN' ? 'en' : 'zh-CN'
const targetPath = Astro.url.pathname.replace(`/${locale}`, `/${targetLocale}`)
---

<a
  href={targetPath}
  class="text-muted-foreground text-sm transition-colors hover:text-foreground"
>
  {t('footer.switchTo')}
</a>
