---
import type { Locale } from '@/i18n/utils'
import { defaultLocale, useTranslations } from '@/i18n/utils'
import Icon from '@/components/icon.astro'

const locale = (Astro.currentLocale ?? defaultLocale) as Locale
const t = useTranslations(locale)
---

<dialog
  id="search-dialog"
  class="m-0 mx-auto mt-[20vh] w-[calc(100%-2rem)] max-w-lg rounded-xl border border-border bg-popover p-0 text-popover-foreground shadow-lg backdrop:bg-black/50"
>
  <div class="flex items-center border-border border-b px-4">
    <Icon name="search" class="mr-2 size-4 shrink-0 text-muted-foreground" />
    <input
      id="search-input"
      type="text"
      placeholder={t('search.placeholder')}
      class="flex h-12 w-full bg-transparent text-base outline-none placeholder:text-muted-foreground sm:text-sm"
      autocomplete="off"
    />
  </div>
  <div id="search-results" class="max-h-80 overflow-y-auto p-2">
    <p class="py-6 text-center text-muted-foreground text-sm" id="search-hint">
      {t('search.hint')}
    </p>
    <div class="hidden" id="search-no-results">
      <div class="flex flex-col items-center py-8">
        <Icon name="search-x" class="size-8 text-muted-foreground/40" />
        <p class="mt-3 text-muted-foreground text-sm">{t('search.noResults')}</p>
      </div>
    </div>
    <div id="search-loading" class="hidden space-y-2 p-2">
      <div class="h-12 animate-pulse rounded-md bg-muted"></div>
      <div class="h-12 animate-pulse rounded-md bg-muted"></div>
      <div class="h-12 animate-pulse rounded-md bg-muted"></div>
    </div>
    <div id="search-error" class="hidden">
      <p class="py-6 text-center text-muted-foreground text-sm">{locale === 'zh-CN' ? '搜索失败' : 'Search failed'}</p>
    </div>
    <div id="search-items"></div>
  </div>
</dialog>

<script>
  function getLocale(): string {
    return document.documentElement.lang || 'zh-CN'
  }

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault()
      const dialog = document.getElementById('search-dialog') as HTMLDialogElement | null
      const input = document.getElementById('search-input') as HTMLInputElement | null
      if (dialog && input) {
        dialog.showModal()
        input.focus()
      }
    }
  })

  {
    const dialog = document.getElementById('search-dialog') as HTMLDialogElement
    const input = document.getElementById('search-input') as HTMLInputElement
    const hint = document.getElementById('search-hint')!
    const noResults = document.getElementById('search-no-results')!
    const loading = document.getElementById('search-loading')!
    const errorEl = document.getElementById('search-error')!
    const items = document.getElementById('search-items')!

    let debounceTimer: ReturnType<typeof setTimeout>
    let abortController: AbortController | null = null

    function showOnly(el: HTMLElement) {
      for (const s of [hint, noResults, loading, errorEl, items]) {
        s.classList.toggle('hidden', s !== el)
      }
    }

    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close()
    })

    dialog.addEventListener('close', () => {
      input.value = ''
      abortController?.abort()
      abortController = null
      clearTimeout(debounceTimer)
      items.innerHTML = ''
      showOnly(hint)
    })

    input.addEventListener('input', () => {
      clearTimeout(debounceTimer)
      const query = input.value.trim()

      if (!query) {
        items.innerHTML = ''
        showOnly(hint)
        return
      }

      debounceTimer = setTimeout(() => performSearch(query), 500)
    })

    async function performSearch(query: string) {
      abortController?.abort()
      abortController = new AbortController()

      showOnly(loading)

      try {
        const res = await fetch('/api/search', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ query }),
          signal: abortController.signal,
        })
        const data = await res.json()
        renderResults(data.results)
      } catch (e) {
        if ((e as Error).name !== 'AbortError') {
          showOnly(errorEl)
        }
      }
    }

    function escapeHtml(str: string): string {
      const el = document.createElement('span')
      el.textContent = str
      return el.innerHTML
    }

    function renderResults(results: Array<Record<string, unknown>>) {
      const isZh = getLocale() === 'zh-CN'

      if (!results?.length) {
        showOnly(noResults)
        return
      }

      const html = results
        .map((r) => {
          const title = escapeHtml((isZh ? r.titleZh : r.titleEn) as string)
          const summary = isZh ? r.summaryZh : r.summaryEn
          const url = escapeHtml(r.url as string)
          return `<a href="${url}" target="_blank" rel="noopener noreferrer" class="block rounded-md px-3 py-2 text-sm transition-colors hover:bg-accent">
        <div class="font-medium">${title}</div>
        ${summary ? `<div class="mt-0.5 line-clamp-1 text-muted-foreground text-xs">${escapeHtml(summary as string)}</div>` : ''}
      </a>`
        })
        .join('')

      const count = results.length
      const label = isZh
        ? `找到 ${count} 篇相关文章`
        : `Found ${count} articles`
      items.innerHTML = `<p class="px-3 py-1.5 text-muted-foreground text-xs">${label}</p>${html}`
      showOnly(items)
    }
  }
</script>
