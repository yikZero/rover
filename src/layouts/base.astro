---
import { getAbsoluteLocaleUrl } from 'astro:i18n'

import '@/styles/globals.css'
import Header from '@/components/header.astro'
import SearchDialog from '@/components/search-dialog.astro'
import { defaultLocale, stripLocalePrefix, useTranslations } from '@/i18n/utils'
import type { Locale } from '@/i18n/utils'

interface Props {
  title?: string
  description?: string
  locale?: Locale
  ogType?: 'website' | 'article'
}

const {
  title = 'Rover',
  locale = defaultLocale,
  ogType = 'website',
} = Astro.props
const description = Astro.props.description ?? useTranslations(locale)('site.description')

const cleanPath = stripLocalePrefix(Astro.url.pathname)
const alternateLocale: Locale = locale === defaultLocale ? 'en' : 'zh-CN'
const canonicalUrl = getAbsoluteLocaleUrl(locale, cleanPath)
const alternateUrl = getAbsoluteLocaleUrl(alternateLocale, cleanPath)
const zhUrl = getAbsoluteLocaleUrl(defaultLocale, cleanPath)
---

<html lang={locale} class="antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={locale} href={canonicalUrl} />
    <link rel="alternate" hreflang={alternateLocale} href={alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={zhUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={locale} />
    <meta property="og:site_name" content="Rover" />
    <meta property="og:image" content={`${Astro.site}og-image.png`} />
    <meta property="og:image:width" content="2400" />
    <meta property="og:image:height" content="1260" />
    <meta property="og:image:type" content="image/png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${Astro.site}og-image.png`} />
    <link rel="alternate" type="application/rss+xml" title="Rover" href="/rss.xml" />
    <slot name="head" />

  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-background focus:px-4 focus:py-2 focus:text-sm focus:text-foreground focus:shadow-lg focus:outline-none focus:ring-2 focus:ring-ring">
      Skip to main content
    </a>
    <Header />
    <main id="main-content" class="mx-auto max-w-5xl px-6 py-6 md:py-8">
      <slot />
    </main>
    <footer class="mx-auto max-w-5xl px-6 pb-8 pt-4 ">
      <div class="border-border/50 border-t pt-4">
        <p class="text-center text-muted-foreground text-sm">
          Designed & built by <a href="https://ro.yikzero.com/" target="_blank" rel="noopener noreferrer" class="text-muted-foreground underline decoration-muted-foreground/30 transition-colors hover:text-foreground">yikZero</a>
        </p>
      </div>
    </footer>
    <SearchDialog />
  </body>
</html>
