---
import { ClientRouter } from 'astro:transitions'
import '@/styles/globals.css'
import Header from '@/components/header.astro'
import SearchDialog from '@/components/search-dialog.astro'

interface Props {
  title?: string
  description?: string
  locale?: 'zh-CN' | 'en'
}

const {
  title = 'Rover',
  description = 'AI-curated daily tech article digest',
  locale = 'zh-CN',
} = Astro.props
---

<html lang={locale} class="antialiased" transition:animate="none">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter fallback="none" />
  </head>
  <body>
    <Header />
    <main class="mx-auto max-w-5xl px-6 py-6 md:py-10">
      <slot />
    </main>
    <footer class="mx-auto max-w-5xl px-6 pb-8 pt-4">
      <div class="border-border/50 border-t pt-4">
        <p class="text-center text-muted-foreground/50 text-xs">
          Designed & built by <a href="https://ro.yikzero.com/" target="_blank" rel="noopener noreferrer" class="text-muted-foreground/70 transition-colors hover:text-muted-foreground">yikZero</a>
        </p>
      </div>
    </footer>
    <SearchDialog />
  </body>
</html>
