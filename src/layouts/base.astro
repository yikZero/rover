---
import { getAbsoluteLocaleUrl } from 'astro:i18n'
import { ClientRouter } from 'astro:transitions'
import '@/styles/globals.css'
import Header from '@/components/header.astro'
import SearchDialog from '@/components/search-dialog.astro'
import { defaultLocale, stripLocalePrefix, useTranslations } from '@/i18n/utils'
import type { Locale } from '@/i18n/utils'

interface Props {
  title?: string
  description?: string
  locale?: Locale
  ogType?: 'website' | 'article'
}

const {
  title = 'Rover',
  locale = defaultLocale,
  ogType = 'website',
} = Astro.props
const description = Astro.props.description ?? useTranslations(locale)('site.description')

const cleanPath = stripLocalePrefix(Astro.url.pathname)
const alternateLocale: Locale = locale === defaultLocale ? 'en' : 'zh-CN'
const canonicalUrl = getAbsoluteLocaleUrl(locale, cleanPath)
const alternateUrl = getAbsoluteLocaleUrl(alternateLocale, cleanPath)
const zhUrl = getAbsoluteLocaleUrl(defaultLocale, cleanPath)
---

<html lang={locale} class="antialiased" transition:animate="none">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <style>
      html { background-color: #ffffff; color-scheme: light dark; }
      @media (prefers-color-scheme: dark) { html { background-color: #0a0a0a; } }
    </style>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={locale} href={canonicalUrl} />
    <link rel="alternate" hreflang={alternateLocale} href={alternateUrl} />
    <link rel="alternate" hreflang="x-default" href={zhUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={locale} />
    <meta property="og:site_name" content="Rover" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="alternate" type="application/rss+xml" title="Rover" href="/rss.xml" />
    <slot name="head" />
    <script is:inline>
      (function() {
        var s = localStorage.getItem('preferred-locale')
        if (!s) return
        var p = location.pathname
        var isEn = p === '/en' || p === '/en/' || p.startsWith('/en/')
        var cur = isEn ? 'en' : 'zh-CN'
        if (s === cur) return
        if (s === 'en' && !isEn) {
          location.replace('/en' + (p === '/' ? '' : p))
        } else if (s === 'zh-CN' && isEn) {
          location.replace(p.replace(/^\/en\/?/, '/') || '/')
        }
      })()
    </script>
    <ClientRouter fallback="none" />
  </head>
  <body>
    <Header />
    <main class="mx-auto max-w-5xl px-6 py-6 md:py-10">
      <slot />
    </main>
    <footer class="mx-auto max-w-5xl px-6 pb-8 pt-4 safe-area-bottom">
      <div class="border-border/50 border-t pt-4">
        <p class="text-center text-muted-foreground/50 text-xs">
          Designed & built by <a href="https://ro.yikzero.com/" target="_blank" rel="noopener noreferrer" class="text-muted-foreground/70 transition-colors hover:text-muted-foreground">yikZero</a>
        </p>
      </div>
    </footer>
    <SearchDialog />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {})
        }, { once: true })
      }
    </script>
  </body>
</html>
