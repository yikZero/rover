---
export const prerender = false

import type { Locale } from '@/i18n/utils'
import { defaultLocale, useTranslations } from '@/i18n/utils'
import BaseLayout from '@/layouts/base.astro'
import StatusState from '@/components/status-state.astro'
import { getRelativeLocaleUrl } from 'astro:i18n'

const locale = (Astro.currentLocale ?? defaultLocale) as Locale
const t = useTranslations(locale)
---

<BaseLayout locale={locale} title={t('notFound.pageTitle')}>
  <StatusState
    icon="file-search"
    title={t('notFound.title')}
    description={t('notFound.description')}
    href={getRelativeLocaleUrl(locale, '/')}
    ctaIcon="arrow-left"
    ctaLabel={t('notFound.backHome')}
  />
</BaseLayout>
