---
import { getLocaleStaticPaths } from '@/i18n/utils'
import type { Locale } from '@/i18n/utils'
import Home from '@/components/pages/home.astro'

export function getStaticPaths() {
  return getLocaleStaticPaths()
}

const { locale } = Astro.props as { locale: Locale }
---
<Home locale={locale} />
