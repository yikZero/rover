---
import type { Locale } from '@/i18n/utils'
import { defaultLocale, locales } from '@/i18n/utils'
import type { DigestWithArticles } from '@/lib/types'
import { getAllDigests } from '@/lib/queries'
import DigestDate from '@/components/pages/digest-date.astro'

export async function getStaticPaths() {
  const digests = await getAllDigests()
  return locales.flatMap((locale) =>
    digests.map((digest) => ({
      params: {
        locale: locale === defaultLocale ? undefined : locale,
        date: digest.date,
      },
      props: { locale, digest },
    })),
  )
}

const { locale, digest } = Astro.props as { locale: Locale; digest: DigestWithArticles }
---
<DigestDate locale={locale} date={digest.date} digest={digest} />
