---
import type { Locale } from '@/i18n/utils'
import { locales } from '@/i18n/utils'
import { getAllDigestDates } from '@/lib/queries'
import DigestDate from '@/components/pages/digest-date.astro'

export async function getStaticPaths() {
  const dates = await getAllDigestDates()
  return locales.flatMap((locale) =>
    dates.map((date) => ({
      params: { locale: locale === 'zh-CN' ? undefined : locale, date },
      props: { locale, date },
    })),
  )
}

const { locale, date } = Astro.props as { locale: Locale; date: string }
---
<DigestDate locale={locale} date={date} />
